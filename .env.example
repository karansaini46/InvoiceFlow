DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public
TEST_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/TEST_DATABASE?schema=public
JWT_SECRET=replace-with-a-secure-secret
JWT_REFRESH_SECRET=replace-with-a-secure-refresh-secret
PORT=3000
CLIENT_URL=http://localhost:5173
CLIENT_URLS=https://invoice-flow-client.vercel.app
PUBLIC_INVOICE_BASE_URL=http://localhost:3000
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=replace-with-smtp-user
SMTP_PASS=replace-with-smtp-password
SMTP_FROM="InvoiceFlow <replace-with-smtp-user>"
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
NVIDIA_API_KEY=nvapi_replace_me
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
LLAMA_MODEL=meta/llama-4-scout-17b-16e-instruct
AI_RATE_LIMIT_WINDOW_MS=60000
AI_RATE_LIMIT_MAX_REQUESTS=20
AI_MAX_CONCURRENT_REQUESTS=4

# Redis / BullMQ Settings
REDIS_URL=redis://localhost:6379

# Resend Settings
RESEND_API_KEY=re_replace_me
RESEND_FROM_EMAIL="InvoiceFlow <replace-with-resend-user>"
