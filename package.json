{
  "name": "invoiceflow",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -n client,server -c cyan,green \"pnpm --filter @invoiceflow/client dev\" \"pnpm --filter @invoiceflow/server dev\"",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
