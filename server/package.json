{
  "name": "@invoiceflow/server",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.22.0"
  },
  "scripts": {
    "dev": "nodemon",
    "build": "tsc -p ./tsconfig.json",
    "deploy:build": "prisma generate && tsc -p ./tsconfig.json",
    "db:deploy": "prisma migrate deploy",
    "lint": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.12.3",
    "@types/nodemailer": "^8.0.0",
    "@types/pdfkit": "^0.17.6",
    "bcrypt": "^6.0.0",
    "bottleneck": "^2.19.5",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.7",
    "openai": "^6.37.0",
    "pdfkit": "^0.18.0",
    "pg": "^8.20.0",
    "prisma": "^7.8.0",
    "typescript": "^5.9.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.5",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "vitest": "^4.1.5"
  }
