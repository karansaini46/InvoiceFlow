generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String         @id @default(cuid())
  email               String         @unique
  passwordHash        String
  name                String
  businessName        String?
  businessAddress     String?
  businessPhone       String?
  businessWebsite     String?
  logoUrl             String?
  defaultCurrency     String         @default("USD")
  defaultTaxRate      Float          @default(0)
  defaultPaymentTerms String         @default("Net 30")
  defaultNotes        String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  plan                Plan           @default(FREE)
  stripeCustomerId    String?
  invoices            Invoice[]
  proposals           Proposal[]
  aiUsageLogs         AiUsageLog[]
  followUpRules       FollowUpRule[]
}

model Invoice {
  id                       String        @id @default(cuid())
  number                   String
  userId                   String
  clientName               String
  clientEmail              String
  clientAddress            String
  issueDate                DateTime
  dueDate                  DateTime
  status                   InvoiceStatus @default(DRAFT)
  currency                 String
  notes                    String
  subtotal                 Float
  taxRate                  Float
  taxAmount                Float
  total                    Float
  scheduledSendAt          DateTime?
  sentAt                   DateTime?
  paidAt                   DateTime?
  stripeCheckoutSessionId  String?
  stripePaymentIntentId    String?
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt
  user                     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  lineItems                LineItem[]
  aiUsageLogs              AiUsageLog[]
  followUpRules            FollowUpRule[]
  followUpLogs             FollowUpLog[]
  emailEvents              EmailEvent[]

  @@unique([userId, number])
  @@index([userId])
}

model AiUsageLog {
  id               String   @id @default(cuid())
  userId           String
  invoiceId        String?
  feature          String
  model            String
  success          Boolean
  latencyMs        Int
  promptTokens     Int?
  completionTokens Int?
  totalTokens      Int?
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoice          Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([invoiceId, feature, createdAt])
}

model LineItem {
  id          String  @id @default(cuid())
  invoiceId   String
  description String
  quantity    Float
  unitPrice   Float
  amount      Float
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model FollowUpRule {
  id         String        @id @default(cuid())
  invoiceId  String?
  userId     String
  offsetDays Int
  enabled    Boolean       @default(true)
  createdAt  DateTime      @default(now())
  invoice    Invoice?      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs       FollowUpLog[]

  @@index([userId])
  @@index([invoiceId])
}

model FollowUpLog {
  id              String       @id @default(cuid())
  invoiceId       String
  ruleId          String
  sentAt          DateTime     @default(now())
  bullmqJobId     String
  resendMessageId String?
  invoice         Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  rule            FollowUpRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model EmailEvent {
  id         String   @id @default(cuid())
  invoiceId  String?
  type       String
  email      String
  occurredAt DateTime @default(now())
  payload    String?
  invoice    Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([invoiceId])
  @@index([email])
}

model Proposal {
  id          String         @id @default(cuid())
  userId      String
  clientName  String
  clientEmail String
  title       String
  content     String
  status      ProposalStatus @default(DRAFT)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum Plan {
  FREE
  PRO
}

enum InvoiceStatus {
  DRAFT
  SCHEDULED
  SENT
  VIEWED
  PAID
  OVERDUE
  CANCELLED
}

enum ProposalStatus {
  DRAFT
  SENT
  ACCEPTED
  DECLINED
}
